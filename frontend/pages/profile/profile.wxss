/* 用户信息卡片 */
.user-card {
  margin: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  padding: 40rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(135deg, #007aff, #00c4ff);
  z-index: 0;
}

.user-info {
  position: relative;
  z-index: 1;
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.user-meta {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 32rpx;
  background: #fff;
}

/* 功能菜单 */
.menu-container {
  margin: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  position: relative;
  transition: all 0.3s ease;
}

.menu-item:active {
  background: #f8f8f8;
}

.menu-item::after {
  content: '';
  position: absolute;
  left: 120rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #eee;
}

.menu-item:last-child::after {
  display: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

/* 操作按钮 */
.action-container {
  margin: 60rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #ff4444;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255,77,79,0.15);
  transition: all 0.3s ease;
}

.logout-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 弹窗样式 */
.van-dialog {
  border-radius: 24rpx !important;
  overflow: hidden;
}

.dialog-content {
  padding: 40rpx 60rpx;
}

.dialog-content input {
  width: 100%;
  height: 100rpx;
  border-bottom: 2rpx solid #007aff;
  font-size: 32rpx;
  padding: 0 20rpx;
}

button[slot="footer"] {
  background: #007aff !important;
  color: #fff !important;
  border-radius: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 30rpx 30rpx;
}

/* 新增按钮样式 */
.return-home-btn {
  width: 80%;
  margin: 30rpx auto 0;
  background: #fff;
  color: #007aff;
  border-radius: 50rpx;
  border: 1rpx solid #007aff;
}

/* 新增按钮交互效果 */
.button-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  vertical-align: middle;
  margin-right: 15rpx;
}

/* 调整容器间距 */
.action-container {
  margin: 60rpx 30rpx 0;
  padding-bottom: 60rpx;
}
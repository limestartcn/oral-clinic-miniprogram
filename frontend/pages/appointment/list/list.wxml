<!-- list.wxml -->
<view class="container" style="position: relative; left: 0rpx; top: -183rpx; height: 1214rpx; display: flex; box-sizing: border-box">
  <view class="tabs" style="position: sticky; left: NaNrpx; top: -664rpx; width: 720rpx; display: flex; box-sizing: border-box">
    <block wx:for="{{tabs}}" wx:key="id">
      <view 
        class="tab-item {{activeTab === item.id ? 'active' : ''}}"
        bindtap="switchTab" 
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </block>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <van-loading size="24px">加载中...</van-loading>
  </view>

  <scroll-view wx:else scroll-y class="list" style="height: 900rpx; display: block; box-sizing: border-box; position: relative; left: 1rpx; top: -19rpx">
    <block wx:for="{{appointments}}" wx:key="id">
      <view class="card" catchtap="navigateToDetail" data-id="{{item.id}}">
        <view class="header">
          <text class="time">{{item.formattedTime}}</text>
          <text class="status" data-status="{{item.status}}">
            {{statusMap[item.status]}}
          </text>
        </view>
        <view class="content">
          <view class="info-item">
            <text class="label">科室</text>
            <text>{{item.department || '未指定科室'}}</text>
          </view>
          <view class="info-item">
            <text class="label">医生</text>
            <text>{{item.doctorName || '未指定医生'}}</text>
          </view>
        </view>
        <view class="footer" wx:if="{{item.status < 3}}">
          <van-button 
            custom-class="cancel-btn"
            bindtap="handleCancel" 
            data-id="{{item.id}}"
            plain
            hairline
          >取消预约</van-button>
        </view>
      </view>
    </block>
    <view wx:if="{{appointments.length === 0}}" class="empty">
      <image src="/images/icon-empty.png"></image>
      <text>暂无预约记录</text>
    </view>
  </scroll-view>
</view>
/* list.wxss */
.container {
  background: #f8f9fa;
  min-height: 100vh;
}

/* 标签栏样式 */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 40rpx; /* 增加左右内边距 */
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s ease;
  position: relative;
  margin: 0 10rpx; /* 增加标签间距 */
  border-radius: 8rpx;
  background: #f8f9fa;
}

.tab-item.active {
  color: #fff;
  background: #007AFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0,122,255,0.25);
}

.tab-item:not(.active):active {
  background: #f0f0f0; /* 增加点击反馈 */
}

/* 移除原有下划线样式 */
.tab-item.active::after {
  display: none;
}

/* 新增过渡动画 */
@keyframes tabScale {
  0% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

.tab-item.active {
  animation: tabScale 0.3s ease;
}

/* 预约卡片 */
.card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: transform 0.2s ease;
}

.card:active {
  transform: scale(0.98);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.time {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
}

.status[data-status="1"] { /* 待确认 */
  background: #fff3e0;
  color: #ff9100;
}

.status[data-status="2"] { /* 已预约 */
  background: #e3f2fd;
  color: #2196f3;
}

.status[data-status="3"] { /* 已完成 */
  background: #e8f5e9;
  color: #4caf50;
}

.status[data-status="4"] { /* 已取消 */
  background: #f5f5f5;
  color: #9e9e9e;
}

/* 信息展示 */
.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.label {
  color: #666;
  min-width: 120rpx;
  display: flex;
  align-items: center;
}

.label::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  background: #007AFF;
  border-radius: 50%;
  margin-right: 12rpx;
}

/* 操作按钮 */
.footer {
  margin-top: 32rpx;
  padding-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.cancel-btn {
  width: auto;
  min-width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: #ff4444;
  border: 1rpx solid #ff4444;
  border-radius: 40rpx;
  background: none;
  padding: 0 32rpx;
  transition: all 0.2s ease;
}

.cancel-btn:active {
  background: rgba(255,68,68,0.05);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}
.container {
  height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.step-indicator {
  font-size: 28rpx;
  color: #666;
}

.loading-wrapper, .error-wrapper, .empty {
  height: 80vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
}

.error-icon, .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.error-msg {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.retry-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: white;
  border-radius: 40rpx;
}

.department-list {
  height: calc(100vh - 200rpx);
}

.department-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.department-item.active {
  background: #e6f4ff;
  border: 1rpx solid #007aff;
}

.department-icon {
  width: 100rpx;
  height: 100rpx;
  margin-right: 30rpx;
}

.info {
  flex: 1;
}

.name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.arrow {
  width: 40rpx;
  height: 40rpx;
  margin-left: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}
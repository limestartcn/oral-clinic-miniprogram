.container {
  height: 100vh;
  background: #f5f5f5;
  padding: 30rpx 30rpx 0;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  padding: 10rpx;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 0 20rpx;
}

.step-indicator {
  font-size: 28rpx;
  color: #666;
}

.doctor-info {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.detail {
  flex: 1;
}

.name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.department {
  font-size: 26rpx;
  color: #666;
}

.date-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 30rpx;
}

/* 日期选择器整体样式 */
.date-picker {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

/* 日历图标样式 */
.icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

/* 日期显示区域样式 */
.date-display {
  display: flex;
  align-items: center;
}

.date-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.week {
  font-size: 26rpx;
  color: #666;
}

.time-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 120rpx;
}

.time-list {
  max-height: 600rpx;
}

.time-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.time-item.active {
  background: #e6f4ff;
  border: 1rpx solid #007aff;
}

.time-item.disabled {
  opacity: 0.5;
}

.time {
  font-size: 28rpx;
  color: #333;
}

.status {
  font-size: 26rpx;
  color: #07c160;
}

.time-item.disabled .status {
  color: #ff4d4f;
}

.time-item.active {
  background: #e6f4ff;
  border: 2rpx solid #007aff; /* 加粗边框 */
  transform: scale(1.02); /* 轻微放大效果 */
  transition: all 0.2s ease; /* 添加过渡动画 */
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.next-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
}

.next-btn[disabled] {
  background: #cccccc;
}

.loading-wrapper,
.error-wrapper,
.empty {
  height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
}

.error-icon,
.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.error-msg {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.retry-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: white;
  border-radius: 40rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 固定日期栏样式 */
.selected-date-header {
  position: sticky;
  top: 0;
  z-index: 999;
  width: 100%;
  padding: 20rpx 30rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  text-align: center;
}

/* pages/appointment/create/step4-confirm/index.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  padding: 10rpx;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin: 0 20rpx;
}

.step-indicator {
  font-size: 28rpx;
  color: #666;
}

.info-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 120rpx;
}

.section {
  margin: 20rpx 0;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.doctor-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.detail {
  flex: 1;
}

.name {
  font-size: 32rpx;
  color: #333;
}

.department {
  font-size: 26rpx;
  color: #666;
}

.time-info {
  font-size: 28rpx;
  color: #333;
}

.date {
  margin-right: 20rpx;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

.input, .textarea {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  margin: 20rpx 0;
  font-size: 28rpx;
}

.textarea {
  height: 200rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
}

.submit-btn[disabled] {
  background: #cccccc;
}
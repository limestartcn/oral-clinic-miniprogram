.container {
  height: 100vh;
  background: #f5f5f5;
  padding: 30rpx 30rpx 0;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  padding: 10rpx;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 0 20rpx;
}

.step-indicator {
  font-size: 28rpx;
  color: #666;
}

.department-info {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.department-info .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.department-info .name {
  font-size: 30rpx;
  color: #333;
}

.loading-wrapper,
.error-wrapper,
.empty {
  height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
}

.error-icon,
.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.error-msg {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
  max-width: 80%;
  text-align: center;
}

.retry-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: white;
  border-radius: 40rpx;
}

.doctor-list {
  height: calc(100vh - 300rpx);
}

.doctor-card {
  display: flex;
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  min-width: 0;
}

.base-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.name {
  font-size: 32rpx;
  color: #333;
  margin-right: 20rpx;
}

.title {
  font-size: 26rpx;
  color: #666;
  margin-right: 30rpx;
}

.rating {
  display: flex;
  align-items: center;
}

.star {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.specialty {
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 15rpx;
  margin-bottom: 20rpx;
}

.label {
  color: #666;
  font-size: 26rpx;
}

.text {
  color: #333;
  font-size: 26rpx;
}

.stat {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 26rpx;
}

.stat-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.arrow {
  width: 40rpx;
  height: 40rpx;
  margin-left: 20rpx;
  align-self: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}
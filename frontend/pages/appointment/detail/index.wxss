/* pages/appointment/detail/index.wxss */
/* ===== 基础容器样式 ===== */
.container {
  padding: 32rpx;
  background: #f5f6f8;
  min-height: 100vh;
}

/* ===== 信息卡片 ===== */
.info-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
  margin-bottom: 32rpx;
}

.card-header {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #eee;
}

/* ===== 信息项 ===== */
.info-group {
  margin: 32rpx 0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed #eee;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 30rpx;
  color: #333;
}

.highlight {
  color: #1989fa;
  font-weight: 500;
}

/* ===== 医生信息区块 ===== */
.doctor-info {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin: 24rpx 0;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.doctor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 32rpx;
}

.doctor-detail {
  flex: 1;
}

.doctor-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.doctor-title {
  font-size: 26rpx;
  color: #666;
}

/* ===== 状态区块 ===== */
.status-container {
  padding: 24rpx 0;
}

.status-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.status-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-badge {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 状态颜色配置 */
.status-1 { background: #fff3e0; color: #ff9800; } /* 待支付 */
.status-2 { background: #e8f5e9; color: #4caf50; } /* 已预约 */
.status-3 { background: #f5f5f5; color: #666; }    /* 已完成 */
.status-4 { background: #ffebee; color: #f44336; } /* 已取消 */

.status-desc {
  font-size: 24rpx;
  color: #999;
}

/* ===== 操作按钮组 ===== */
.action-buttons {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.payment-btn {
  background: linear-gradient(135deg, #1989fa, #2ba3ff) !important;
  border-radius: 50rpx !important;
  height: 88rpx !important;
}

.chat-btn {
  background: #07c160 !important;
  border-radius: 50rpx !important;
}

.cancel-btn {
  border-color: #969799 !important;
  color: #969799 !important;
}

/* ===== 评价弹窗（优化版）===== */
.review-popup {
  width: 680rpx;
  padding: 48rpx;
  box-sizing: border-box;
  background: #fff;
  border-radius: 24rpx;
}

/* 标题区 */
.popup-header {
  text-align: center;
  margin-bottom: 40rpx;
}
.popup-header text {
  font-size: 38rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 2rpx;
}
.title-line {
  width: 120rpx;
  height: 8rpx;
  background: #1989fa;
  margin: 24rpx auto 0;
  border-radius: 4rpx;
  opacity: 0.8;
}

/* 评分区 */
.rate-section {
  margin: 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.rate-tips {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 48rpx;
}
.van-rate {
  transform: scale(1.2);
}
.van-rate__icon {
  margin: 0 16rpx !important;
  font-size: 48rpx !important;
}

/* 输入区 */
.comment-section {
  margin: 48rpx 0;
}
.section-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 32rpx;
  display: block;
  font-weight: 500;
}
.comment-input {
  width: 100%;
  min-height: 280rpx;
  padding: 32rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  border: 2rpx solid #e0e0e0;
  transition: all 0.3s;
}
.comment-input:focus {
  border-color: #1989fa;
  box-shadow: 0 4rpx 16rpx rgba(25, 137, 250, 0.1);
}

/* 操作按钮 */
.action-btns {
  display: flex;
  justify-content: space-between;
  margin-top: 64rpx;
  gap: 32rpx;
}
.cancel-btn {
  flex: 1;
  height: 96rpx !important;
  background: #f5f5f5 !important;
  border: none !important;
  color: #666 !important;
  border-radius: 16rpx !important;
  font-size: 32rpx;
}
.submit-btn {
  flex: 1;
  height: 96rpx !important;
  background: linear-gradient(135deg, #1989fa, #2ba3ff) !important;
  border-radius: 16rpx !important;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.3);
}

/* ===== 其他辅助样式 ===== */
.placeholder-style {
  color: #c0c4cc;
  font-size: 28rpx;
  font-style: italic;
}

.button-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #fff !important;
}
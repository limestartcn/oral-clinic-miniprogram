/* pages/medical-records/index.wxss */
/* 基础样式 */
.container {
  height: 100vh;
  background: #f8f9fa;
}

/* 状态容器 */
.status-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.status-text {
  font-size: 28rpx;
  color: #666;
}

.error-text {
  color: #ff4444;
  margin-bottom: 40rpx;
}

/* 病例卡片 */
.record-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.header-left {
  flex: 1;
}

.record-date {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-right: 20rpx;
}

.department-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #e8f4ff;
  border-radius: 8rpx;
  color: #007aff;
  font-size: 24rpx;
}

.doctor-name {
  font-size: 28rpx;
  color: #666;
}

/* 内容区块 */
.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin: 32rpx 0 16rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: #007aff;
  border-radius: 4rpx;
}

.diagnosis-content,
.treatment-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
}

/* 用药处方 */
.medication-item {
  display: flex;
  align-items: baseline;
  margin: 24rpx 0;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.medication-name {
  font-size: 28rpx;
  color: #333;
  min-width: 160rpx;
  margin-right: 24rpx;
}

.medication-detail {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.followup {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff8e6;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.followup-label {
  color: #ff9500;
  margin-right: 12rpx;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.attachment-btn {
  flex: 1;
  margin-right: 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  color: #666;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.attachment-btn[disabled] {
  opacity: 0.5;
}

.detail-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  vertical-align: middle;
}

/* 空状态 */
.empty-container {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  color: #999;
  font-size: 28rpx;
  margin-top: 24rpx;
}
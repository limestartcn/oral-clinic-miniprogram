/* pages/chat/index.wxss */
/* ================== 全局容器 ================== */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* ================== 顶部医生信息栏 ================== */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
  z-index: 999;
}

.header-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #f0f0f0;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.department {
  font-size: 24rpx;
  color: #666;
  line-height: 1.2;
}

/* ================== 消息列表区域 ================== */
.message-list {
  flex: 1;
  padding-bottom: 160rpx; /* 适配输入框高度 */
  padding: 20rpx 30rpx 120rpx; /* 底部留出输入区域空间 */
  overflow-y: auto;
  box-sizing: border-box;
}

/* ================== 单条消息容器 ================== */
.message-item {
  display: flex;
  margin: 40rpx 0;
  width: 100%;
  box-sizing: border-box;
}

/* ================== 头像样式 ================== */
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  align-self: flex-start; /* 头像始终顶部对齐 */
  border: 2rpx solid #f0f0f0;
}

/* ================== 消息气泡 ================== */
.bubble {
  max-width: 560rpx;
  min-width: 120rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  position: relative;
  word-break: break-word;
}

/* --------------- 左对齐消息（医生消息） --------------- */
.message-item.left {
  flex-direction: row;
  justify-content: flex-start;
}

.message-item.left .bubble {
  margin-left: 20rpx; 
  margin-right: 0;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

/* --------------- 右对齐消息（用户消息） --------------- */
.message-item.right {
  flex-direction: row;
  justify-content: flex-end;
}

.message-item.right .bubble {
  margin-right: 20rpx;
  margin-left: 0;
  background: #07c160;
  color: #fff;
}

/* ================== 图片消息样式 ================== */
.image-message {
  max-width: 400rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  overflow: hidden;
  position: relative;
}

.image-message::after {
  content: " ";
  position: absolute;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
  background: rgba(0,0,0,0.02);
}

.image-message image {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.3s;
}

.image-message:active image {
  transform: scale(1.02);
}

/* ================== 时间戳样式 ================== */
.time {
  font-size: 24rpx;
  margin-top: 12rpx;
  display: block;
}

/* 对方时间戳（右对齐） */
.message-item.left .time {
  color: rgba(0,0,0,0.5);
  text-align: right;
  padding-left: 20rpx;
}

/* 我方时间戳（左对齐） */
.message-item.right .time {
  color: rgba(255,255,255,0.8);
  text-align: left;
  padding-right: 20rpx;
}

/* ================== 输入区域 ================== */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

/* 图片按钮样式 */
.image-btn {
  margin-right: 20rpx;
  flex-shrink: 0;
  padding: 12rpx;
  background: #f8f8f8;
  border-radius: 50%;
}

/* 输入框容器 */
.van-field {
  flex: 1;
  margin: 0 20rpx;
  background: #f8f8f8;
  border-radius: 40rpx;
  padding: 0 24rpx !important;
  min-height: 80rpx;
}

/* 发送按钮 */
.send-btn {
  margin-left: 20rpx;
  border-radius: 40rpx !important;
  height: 80rpx;
  line-height: 80rpx !important;
  padding: 0 30rpx !important;
}
/* pages/doctor/appointments/index.wxss */

/* 容器布局 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 头部区域 */
.header {
  padding: 20rpx 32rpx;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 预约列表 */
.list {
  flex: 1;
  padding: 20rpx 32rpx;
}

/* 预约卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.time {
  font-size: 30rpx;
  color: #666;
}

/* 状态样式（修正语法） */
.status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 不同状态颜色 */
.status[data-status="1"] { /* 待确认 */
  background: #fff3e0;
  color: #ff9800;
}
.status[data-status="2"] { /* 已预约 */
  background: #e3f2fd;
  color: #2196f3;
}
.status[data-status="3"] { /* 已完成 */
  background: #e8f5e9;
  color: #4caf50;
}
.status[data-status="4"] { /* 已取消 */
  background: #f5f5f5;
  color: #9e9e9e;
}

/* 卡片内容 */
.card-body {
  padding: 24rpx 0;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.info-item:last-child { 
  margin-bottom: 0; 
}

.label {
  font-size: 28rpx;
  color: #999;
  min-width: 140rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 操作按钮区域 */
.card-footer {
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.complete-btn {
  background: #007aff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  line-height: 1.4;
}

.complete-btn::after { 
  border: none; 
}

.complete-btn:active {
  opacity: 0.8;
}

/* 空状态 */
.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}

/* 响应式设计 */
@media (min-width: 768px) {
  .card {
    margin: 0 auto 24rpx;
    max-width: 700rpx;
  }
  
  .label {
    min-width: 160rpx;
  }
}

/* 确认按钮样式 */
.confirm-btn {
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  margin-right: 20rpx;
}

/* 双按钮布局 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}
  <view class="user-bar" wx:else>
  <image src="{{userInfo.avatarUrl}}" class="user-avatar"/>
  <text class="welcome-text">欢迎回来，{{userInfo.nickName}}</text>
</view>
-->

<!-- 在用户信息区域添加角色标识 -->
<view class="user-bar" wx:if="{{hasLogin}}">
  <image src="{{userInfo.avatarUrl}}" class="user-avatar"/>
  <view class="user-info">
    <text class="welcome-text">欢迎回来!{{userInfo.nickName}}</text>
    <text class="role-tag role-{{userInfo.roleName}}">
      {{userInfo.roleName}}
    </text>
  </view>
</view>

<!-- 动态菜单 -->
<view class="role-menu">
  <block wx:for="{{getRoleMenu()}}" wx:key="index">
    <view class="menu-item" bindtap="navigateTo{{item.name}}">
      <image src="/images/{{item.icon}}.png"/>
      <text>{{item.name}}</text>
    </view>
  </block>
</view>
.login-container {
  padding: 60rpx;
  text-align: center;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin: 40rpx 0;
}

.form-item {
  margin: 30rpx 0;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

input {
  height: 80rpx;
  font-size: 32rpx;
}

.code-item {
  display: flex;
  justify-content: space-between;
  padding: 0!important;
}

.code-item input {
  flex: 1;
  padding-left: 20rpx;
}

.get-code {
  width: 220rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background: #007aff;
  color: white;
  border-radius: 0 10rpx 10rpx 0;
}

.submit-btn {
  margin-top: 60rpx;
  background: #007aff;
  color: white;
}

.links {
  margin: 40rpx 0;
  display: flex;
  justify-content: space-between;
}

.wechat-login {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-login image {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}
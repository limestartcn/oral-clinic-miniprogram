<view class="login-container">
  <image src="/images/logo.png" class="logo"></image>
  <form bindsubmit="formSubmit">
    <view class="form-item">
      <input 
        name="mobile" 
        type="number" 
        placeholder="请输入手机号"
        maxlength="11"
      />
    </view>
    
    <view class="form-item">
      <input
        name="password"
        password
        placeholder="请输入密码（6-20位）"
        maxlength="20"
      />
    </view>

    <view class="form-item code-item">
      <input
        name="code"
        type="number"
        placeholder="验证码"
        maxlength="6"
      />
      <button 
        class="get-code" 
        bindtap="getSmsCode"
        disabled="{{codeDisabled}}"
      >
        {{codeText}}
      </button>
    </view>

    <button 
      formType="submit" 
      class="submit-btn" 
      loading="{{loading}}"
    >
      登录
    </button>
  </form>

  <view class="links">
    <navigator url="/pages/auth/register/register">立即注册</navigator>
    <navigator url="/pages/auth/forget/forget">忘记密码</navigator>
  </view>

  <view class="wechat-login" bindtap="wechatLogin">
    <image src="/images/icon-wechat.png"></image>
    <text>微信一键登录</text>
  </view>
</view>
/* pages/doctor-detail/index.wxss */
.page-container {
  height: 100vh;
  background: #f5f5f5;
}

/* 医生资料卡片 */
.profile-card {
  display: flex;
  padding: 40rpx;
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.name {
  font-size: 36rpx;
  color: #333;
  margin-right: 20rpx;
}

.title {
  font-size: 26rpx;
  color: #666;
}

.department {
  font-size: 28rpx;
  color: #07c160;
  margin-bottom: 30rpx;
}

.stats {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.value {
  display: block;
  font-size: 34rpx;
  color: #333;
  font-weight: bold;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 内容区块 */
.section {
  padding: 30rpx;
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
  margin: 0 15rpx;
}

.consult-btn {
  background: #f0f0f0;
  color: #333;
}

.appoint-btn {
  background: #07c160;
  color: #fff;
}

/* 操作菜单 */
.action-menu .mask {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
}

.menu-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.cancel-btn {
  text-align: center;
  padding: 30rpx;
  color: #666;
  margin-top: 20rpx;
}

/* 共用状态样式 */
.loading-wrapper,
.error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.retry-btn {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #fff;
  background: #07c160;
  border-radius: 8rpx;
}
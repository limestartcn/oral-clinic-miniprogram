<!--pages/doctor-list/index.wxml-->
<view class="page-container">
  <!-- 科室标题 -->
  <view class="header">
    <view class="title">{{departmentName}} · 医生团队</view>
    <view class="count">共{{doctors.length}}位医生</view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrapper">
    <image src="/images/loading.gif" class="loading-icon"/>
    <text>加载中...</text>
  </view>

  <!-- 错误提示 -->
  <view wx:elif="{{error}}" class="error-wrapper">
    <text>{{error}}</text>
    <button class="retry-btn" bindtap="loadDoctors">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!doctors.length}}" class="empty-wrapper">
    <image src="/images/icon-empty-doctors.png" class="empty-icon"/>
    <text>当前科室暂无医生</text>
  </view>

  <!-- 医生列表 -->
  <scroll-view wx:else scroll-y class="list-container">
    <block wx:for="{{doctors}}" wx:key="id">
      <view 
        class="doctor-card" 
        data-id="{{item.id}}"
        bindtap="navigateToDoctorDetail"
      >
        <!-- 左侧头像 -->
        <image class="avatar" src="{{item.avatar}}"/>

        <!-- 中间信息 -->
        <view class="info">
          <view class="name-row">
            <text class="name">{{item.name}}</text>
            <text class="title">{{item.title}}</text>
          </view>
          <view class="department">{{item.department}}</view>
          <view class="specialty">{{item.specialty}}</view>
          <view class="stats">
            <text class="rating">
              <image src="/images/icon-star.png" class="star-icon"/>
              {{item.rating}}
            </text>
            <text class="service-count">接诊 {{item.serviceCount}}次</text>
          </view>
        </view>

        <!-- 右侧箭头 -->
        <image class="arrow" src="/images/icon-arrow-right.png"/>
      </view>
    </block>

    <!-- 加载更多提示 -->
    <view wx:if="{{hasMore}}" class="load-more">加载更多...</view>
  </scroll-view>
</view>
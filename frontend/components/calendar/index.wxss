/* components/calendar/index.wxss */
.calendar-container {
  background: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.title {
  font-size: 32rpx;
  color: #333;
}

.arrow {
  font-size: 40rpx;
  padding: 0 30rpx;
  color: #007aff;
}

.weekdays {
  display: flex;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.days {
  display: flex;
  flex-wrap: wrap;
}

.day {
  width: 14.28%; /* 7列布局 */
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}

.day.today {
  background: #e6f4ff;
  border-radius: 50%;
}

.day.selected {
  background: #007aff;
  color: white;
  border-radius: 50%;
}